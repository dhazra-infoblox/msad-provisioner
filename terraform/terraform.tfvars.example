# Example Terraform Variables
# Copy this file to terraform.tfvars and fill in your values

# vCenter Connection
vcenter_server   = "vcenter.example.com"
vcenter_user     = "admin@vsphere.local"
vcenter_password = "your_vcenter_password"

# vSphere Environment
datacenter       = "DC1"
cluster          = "Cluster1"
template         = "WindowsServer2022-Template"
datastore        = "datastore1"
network          = "VM Network"
vm_folder        = "MSAD-Provisioning"

# VMs to provision
# Define your infrastructure here
vms = {
  dc01 = {
    name        = "dc01"
    ip_address  = "192.168.1.10"
    subnet_mask = "255.255.255.0"
    gateway     = "192.168.1.1"
    dns_servers = ["192.168.1.10", "8.8.8.8"]
    cpu         = 4
    memory      = 8192   # MB
    disk        = 100    # GB
  }

  dc02 = {
    name        = "dc02"
    ip_address  = "192.168.1.11"
    subnet_mask = "255.255.255.0"
    gateway     = "192.168.1.1"
    dns_servers = ["192.168.1.10", "192.168.1.11"]
    cpu         = 4
    memory      = 8192
    disk        = 100
  }

  member01 = {
    name        = "member01"
    ip_address  = "192.168.1.50"
    subnet_mask = "255.255.255.0"
    gateway     = "192.168.1.1"
    dns_servers = ["192.168.1.10", "192.168.1.11"]
    cpu         = 2
    memory      = 4096
    disk        = 80
  }

  dhcp01 = {
    name        = "dhcp01"
    ip_address  = "192.168.1.20"
    subnet_mask = "255.255.255.0"
    gateway     = "192.168.1.1"
    dns_servers = ["192.168.1.10", "192.168.1.11"]
    cpu         = 2
    memory      = 4096
    disk        = 60
  }
}
